{
  "colors": {
    "light": {
      "background": "#f5f7fa",
      "surface": "#ffffff",
      "text": "#1a202c",
      "textSecondary": "#718096",
      "textTertiary": "#a0aec0",
      "accent": "#2d9d7f",
      "accentLight": "#7dd3c0",
      "accentDark": "#1d6b5f",
      "success": "#48bb78",
      "error": "#f56565",
      "warning": "#ed8936",
      "info": "#4299e1",
      "input": "#e2e8f0",
      "inputBorder": "#cbd5e0",
      "shadow": "rgba(163, 177, 198, 0.15)",
      "shadowInset": "rgba(255, 255, 255, 0.5)",
      "overlay": "rgba(0, 0, 0, 0.05)"
    },
    "dark": {
      "background": "#1a202c",
      "surface": "#2d3748",
      "surfaceElevated": "#4a5568",
      "text": "#e2e8f0",
      "textSecondary": "#a0aec0",
      "textTertiary": "#718096",
      "accent": "#7dd3c0",
      "accentLight": "#a8e6d7",
      "accentDark": "#2d9d7f",
      "success": "#68d391",
      "error": "#fc8181",
      "warning": "#f6ad55",
      "info": "#63b3ed",
      "input": "#4a5568",
      "inputBorder": "#718096",
      "shadow": "rgba(0, 0, 0, 0.3)",
      "shadowInset": "rgba(255, 255, 255, 0.1)",
      "overlay": "rgba(0, 0, 0, 0.3)"
    },
    "highContrast": {
      "background": "#ffffff",
      "surface": "#ffffff",
      "text": "#000000",
      "accent": "#ff6b35",
      "error": "#d32f2f",
      "success": "#00695c",
      "input": "#ffffff",
      "inputBorder": "#000000"
    }
  },
  "neumorphism": {
    "shadows": {
      "light": {
        "soft": {
          "blur": 12,
          "spread": 2,
          "color": "rgba(163, 177, 198, 0.12)"
        },
        "medium": {
          "blur": 14,
          "spread": 2,
          "color": "rgba(163, 177, 198, 0.15)"
        },
        "deep": {
          "blur": 16,
          "spread": 4,
          "color": "rgba(163, 177, 198, 0.2)"
        },
        "insetLight": {
          "blur": 2,
          "spread": -2,
          "color": "rgba(255, 255, 255, 0.5)"
        },
        "insetDark": {
          "blur": 2,
          "spread": -2,
          "color": "rgba(163, 177, 198, 0.15)"
        }
      },
      "dark": {
        "soft": {
          "blur": 12,
          "spread": 2,
          "color": "rgba(0, 0, 0, 0.2)"
        },
        "medium": {
          "blur": 14,
          "spread": 2,
          "color": "rgba(0, 0, 0, 0.3)"
        },
        "deep": {
          "blur": 16,
          "spread": 4,
          "color": "rgba(0, 0, 0, 0.4)"
        },
        "insetLight": {
          "blur": 2,
          "spread": -2,
          "color": "rgba(255, 255, 255, 0.1)"
        },
        "insetDark": {
          "blur": 2,
          "spread": -2,
          "color": "rgba(0, 0, 0, 0.3)"
        }
      }
    },
    "bevels": {
      "raised": {
        "description": "Element appears lifted from surface",
        "shadow": "medium + insetLight"
      },
      "inset": {
        "description": "Element appears pressed into surface",
        "shadow": "insetDark + insetLight reversed"
      },
      "extruded": {
        "description": "Button or interactive element that pops out",
        "shadow": "deep + insetLight"
      }
    },
    "borderRadius": {
      "small": 8,
      "medium": 12,
      "large": 16,
      "xlarge": 24,
      "circle": "50%"
    }
  },
  "typography": {
    "fontFamily": {
      "primary": "\"Segoe UI\", Roboto, \"Helvetica Neue\", sans-serif",
      "mono": "\"Monaco\", \"Courier New\", monospace"
    },
    "fontSize": {
      "xs": 12,
      "sm": 13,
      "base": 14,
      "lg": 15,
      "xl": 16,
      "2xl": 18,
      "3xl": 20,
      "4xl": 24,
      "5xl": 28,
      "6xl": 32,
      "7xl": 36,
      "8xl": 48
    },
    "fontWeight": {
      "regular": 400,
      "medium": 500,
      "semibold": 600,
      "bold": 700,
      "extrabold": 800
    },
    "lineHeight": {
      "tight": 1.2,
      "normal": 1.5,
      "relaxed": 1.75,
      "loose": 2
    },
    "letterSpacing": {
      "tight": -0.5,
      "normal": 0,
      "wide": 0.5,
      "wider": 1
    }
  },
  "spacing": {
    "xs": 4,
    "sm": 8,
    "md": 12,
    "lg": 16,
    "xl": 24,
    "2xl": 32,
    "3xl": 48,
    "4xl": 64,
    "5xl": 80,
    "6xl": 96
  },
  "touchTarget": {
    "minimum": 44,
    "recommended": 48,
    "large": 56,
    "description": "All interactive elements must be at least 44x44px for mobile accessibility"
  },
  "transitions": {
    "fast": 150,
    "base": 200,
    "slow": 300,
    "verySlow": 500,
    "easing": {
      "easeIn": "cubic-bezier(0.4, 0, 1, 1)",
      "easeOut": "cubic-bezier(0, 0, 0.2, 1)",
      "easeInOut": "cubic-bezier(0.4, 0, 0.2, 1)"
    }
  },
  "zIndex": {
    "hide": -1,
    "base": 0,
    "elevated": 10,
    "sticky": 20,
    "dropdown": 100,
    "modal": 200,
    "popover": 300,
    "tooltip": 400,
    "notification": 500
  }
}
