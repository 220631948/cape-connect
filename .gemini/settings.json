{
  "experimental": {
    "enableAgents": true,
    "plan": true,
    "modelSteering": true,
    "jitContext": true,
    "directWebFetch": true,
    "extensionManagement": true,
    "extensionConfig": true,
    "extensionRegistry": true,
    "extensionReloading": true,
    "toolOutputMasking": {
      "enabled": true
    },
    "useOSC52Paste": true,
    "useOSC52Copy": true
  },
  "general": {
    "plan": {
      "modelRouting": true
    }
  },
  "security": {
    "enableConseca": false
  },
  "skills": {
    "enabled": true
  },
  "mcpServers": {
    "nano-banana": {
      "httpUrl": "https://nano-banana.googleapis.com/mcp"
    },
    "chrome-devtools": {
      "command": "npx",
      "args": [
        "-y",
        "chrome-devtools-mcp"
      ]
    },
    "stitch": {
      "command": "node",
      "args": [
        "mcp/stitch/server.js"
      ],
      "env": {
        "NERFSTUDIO_PATH": "/usr/local/bin/ns-train"
      }
    },
    "computerUse": {
      "command": "node",
      "args": [
        "mcp/computerUse/server.js"
      ]
    },
    "openaware": {
      "command": "node",
      "args": [
        "mcp/openaware/server.js"
      ]
    },
    "cesium": {
      "command": "node",
      "args": [
        "mcp/cesium/server.js"
      ]
    },
    "formats": {
      "command": "node",
      "args": [
        "mcp/formats/server.js"
      ]
    },
    "filesystem": {
      "command": "npx",
      "args": [
        "-y",
        "@modelcontextprotocol/server-filesystem",
        "/home/mr/Desktop/Geographical Informations Systems (GIS)"
      ]
    },
    "postgres": {
      "command": "npx",
      "args": [
        "-y",
        "@modelcontextprotocol/server-postgres",
        "postgresql://postgres:postgres@localhost:5432/capegis"
      ]
    },
    "vercel": {
      "command": "npx",
      "args": [
        "-y",
        "--package",
        "@vercel/sdk",
        "--",
        "mcp",
        "start"
      ],
      "env": {
        "VERCEL_TOKEN": "${VERCEL_TOKEN}"
      }
    },
    "gemini-deep-research": {
      "command": "node",
      "args": [
        ".gemini/extensions/gemini-deep-research/scripts/start.cjs"
      ],
      "env": {
        "GEMINI_API_KEY": "${GEMINI_API_KEY}"
      }
    },
    "context7": {
      "command": "npx",
      "args": [
        "-y",
        "@upstash/context7-mcp",
        "--api-key",
        "${CONTEXT7_API_KEY}"
      ]
    },
    "playwright": {
      "command": "npx",
      "args": [
        "-y",
        "playwright-mcp-server"
      ]
    },
    "docker": {
      "command": "npx",
      "args": [
        "-y",
        "docker-mcp"
      ]
    },
    "localstack": {
      "command": "npx",
      "args": [
        "-y",
        "@localstack/localstack-mcp-server"
      ]
    },
    "sequentialthinking": {
      "command": "docker",
      "args": [
        "run",
        "-i",
        "--rm",
        "danielapatin/sequentialthinking:latest",
        "-transport",
        "stdio"
      ]
    },
    "gis-mcp": {
      "command": "uvx",
      "args": [
        "gis-mcp"
      ]
    },
    "doc-state": {
      "command": "node",
      "args": [
        "mcp/doc-state/server.js"
      ]
    },
    "cesium-ion": {
      "type": "sse",
      "url": "https://mcp.cesium.com/sse",
      "headers": {
        "Authorization": "Bearer ${COPILOT_MCP_CESIUM_ION_TOKEN}"
      }
    },
    "opensky": {
      "command": "node",
      "args": [
        "scripts/opensky-mcp-wrapper.js"
      ]
    },
    "nerfstudio": {
      "command": "python",
      "args": [
        "-m",
        "nerfstudio.mcp_server"
      ]
    }
  }
}