{
  "$schema": "https://capegis.com/schemas/lab-registry/v1.0.0.json",
  "version": "1.0.0",
  "lab_name": "CapeTown GIS Autonomous Research Lab",
  "created": "2026-03-09",
  "geographic_scope": {
    "west": 18.0,
    "south": -34.5,
    "east": 19.5,
    "north": -33.0,
    "crs": "EPSG:4326",
    "description": "City of Cape Town + Western Cape Province"
  },
  "compliance": {
    "framework": "POPIA",
    "jurisdiction": "South Africa",
    "pia_required": true,
    "data_minimisation": true
  },
  "experiments": [
    {
      "id": "EXP-001",
      "name": "Suburb Boundary Baseline",
      "status": "PROPOSED",
      "phase": "C",
      "created": "2026-03-09",
      "hypothesis": "OSM suburb polygons match CoCT official boundaries within 50 m tolerance",
      "datasets": [
        "CoCT Official Boundaries 2023",
        "OSM Western Cape"
      ],
      "metrics": [
        "hausdorff_distance",
        "intersection_over_union"
      ],
      "manifest": "experiments/EXP-001/manifest.yaml",
      "artifacts": "artifacts/EXP-001/",
      "pia": "compliance/EXP-001-pia.md",
      "popia_sensitive": false
    },
    {
      "id": "EXP-002",
      "name": "Land-Use Change Detection",
      "status": "PROPOSED",
      "phase": "E",
      "created": "2026-03-09",
      "hypothesis": "Sentinel-2 time-series can classify 6 CoCT land-use categories at >= 85% F1",
      "datasets": [
        "Sentinel-2 L2A 2020-2024",
        "CoCT Zoning 2022"
      ],
      "metrics": [
        "f1_macro",
        "spatial_confusion_matrix"
      ],
      "manifest": "experiments/EXP-002/manifest.yaml",
      "artifacts": "artifacts/EXP-002/",
      "pia": "compliance/EXP-002-pia.md",
      "popia_sensitive": false
    },
    {
      "id": "EXP-003",
      "name": "Flood-Risk Proxy Model",
      "status": "PROPOSED",
      "phase": "E",
      "created": "2026-03-09",
      "hypothesis": "DEM + impervious-surface features predict NDVI-inferred flood extent at suburb level",
      "datasets": [
        "CoCT DEM 2020",
        "SANBI VEGMAP",
        "SAWS rainfall"
      ],
      "metrics": [
        "auc_roc",
        "precision_at_k_suburbs"
      ],
      "manifest": "experiments/EXP-003/manifest.yaml",
      "artifacts": "artifacts/EXP-003/",
      "pia": "compliance/EXP-003-pia.md",
      "popia_sensitive": false
    },
    {
      "id": "EXP-004",
      "name": "GV Roll Valuation Anomaly",
      "status": "PROPOSED",
      "phase": "F",
      "created": "2026-03-09",
      "hypothesis": "Spatial autocorrelation (Moran's I) can flag under/over-valued parcels in GV Roll 2022",
      "datasets": [
        "CoCT GV Roll 2022",
        "Cadastral parcels"
      ],
      "metrics": [
        "morans_i",
        "recall_known_anomalies"
      ],
      "manifest": "experiments/EXP-004/manifest.yaml",
      "artifacts": "artifacts/EXP-004/",
      "pia": "compliance/EXP-004-pia.md",
      "popia_sensitive": true,
      "popia_note": "GV Roll contains property owner names; anonymise before model ingestion"
    }
  ]
}
