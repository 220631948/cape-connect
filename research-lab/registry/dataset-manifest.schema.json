{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Dataset Manifest",
  "description": "Schema for dataset registration in the CapeTown GIS Research Lab",
  "type": "object",
  "required": ["id", "name", "source", "license", "crs", "privacy_sensitivity"],
  "properties": {
    "id": {
      "type": "string",
      "pattern": "^DS-[0-9]{4}-[a-z0-9-]+$",
      "description": "Unique dataset ID (e.g., DS-0001-coct-gv-roll-2022)"
    },
    "name": { "type": "string" },
    "description": { "type": "string" },
    "version": {
      "type": "string",
      "pattern": "^v[0-9]+\\.[0-9]+\\.[0-9]+$"
    },
    "source": {
      "type": "object",
      "required": ["type"],
      "properties": {
        "type": { "type": "string", "enum": ["url", "api", "file", "database", "synthetic"] },
        "url": { "type": "string", "format": "uri" },
        "api_endpoint": { "type": "string" },
        "access_method": { "type": "string" },
        "last_fetched": { "type": "string", "format": "date-time" }
      }
    },
    "license": {
      "type": "object",
      "required": ["spdx_id", "commercial_use"],
      "properties": {
        "spdx_id": { "type": "string", "description": "SPDX license identifier (e.g., CC-BY-4.0, ODbL-1.0)" },
        "url": { "type": "string", "format": "uri" },
        "commercial_use": { "type": "boolean" },
        "attribution_required": { "type": "boolean" },
        "share_alike": { "type": "boolean" },
        "notes": { "type": "string" }
      }
    },
    "schema": {
      "type": "object",
      "properties": {
        "format": { "type": "string", "enum": ["geojson", "shapefile", "geopackage", "csv", "parquet", "tiff", "pmtiles", "mvt", "other"] },
        "fields": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "name": { "type": "string" },
              "type": { "type": "string" },
              "description": { "type": "string" }
            }
          }
        },
        "geometry_type": { "type": "string", "enum": ["Point", "LineString", "Polygon", "MultiPoint", "MultiLineString", "MultiPolygon", "GeometryCollection", "none"] }
      }
    },
    "crs": {
      "type": "string",
      "description": "Coordinate Reference System (e.g., EPSG:4326)",
      "pattern": "^EPSG:[0-9]+$"
    },
    "spatial_extent": {
      "type": "object",
      "properties": {
        "west": { "type": "number" },
        "south": { "type": "number" },
        "east": { "type": "number" },
        "north": { "type": "number" }
      },
      "description": "Bounding box in CRS coordinates"
    },
    "size": {
      "type": "object",
      "properties": {
        "rows": { "type": "integer" },
        "size_mb": { "type": "number" },
        "partitions": { "type": "integer" }
      }
    },
    "privacy_sensitivity": {
      "type": "string",
      "enum": ["public", "low", "medium", "high", "restricted"],
      "description": "public=open data, low=aggregated, medium=location-based, high=PII, restricted=requires ethics approval"
    },
    "popia_annotation": {
      "type": "object",
      "description": "Required when privacy_sensitivity is 'high' or 'restricted'",
      "properties": {
        "personal_data_handled": { "type": "array", "items": { "type": "string" } },
        "purpose": { "type": "string" },
        "lawful_basis": { "type": "string", "enum": ["consent", "contract", "legal_obligation", "legitimate_interests"] },
        "retention_period": { "type": "string" },
        "subject_rights": {
          "type": "object",
          "properties": {
            "access": { "type": "boolean" },
            "correction": { "type": "boolean" },
            "deletion": { "type": "boolean" },
            "objection": { "type": "boolean" }
          }
        }
      }
    },
    "provenance": {
      "type": "object",
      "properties": {
        "created_at": { "type": "string", "format": "date-time" },
        "created_by": { "type": "string" },
        "processing_steps": { "type": "array", "items": { "type": "string" } },
        "parent_dataset": { "type": "string", "description": "ID of source dataset if derived" }
      }
    },
    "quality": {
      "type": "object",
      "properties": {
        "completeness": { "type": "number", "minimum": 0, "maximum": 1 },
        "known_issues": { "type": "array", "items": { "type": "string" } },
        "validation_status": { "type": "string", "enum": ["not_validated", "schema_valid", "spatially_valid", "fully_validated"] }
      }
    }
  }
}
