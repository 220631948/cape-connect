# CapeTown GIS Hub — Environment Variables Template
# Copy to .env and fill in values. Never commit .env to git.

# ═══════════════════════════════════════════════════════════════════════════════
# [Next.js Core]
# ═══════════════════════════════════════════════════════════════════════════════

# Supabase client-side connection (public, safe to expose in browser)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Server-side Supabase key (NEVER expose to browser — server routes only)
SUPABASE_SERVICE_ROLE_KEY=

# Google Street View integration for property detail views
NEXT_PUBLIC_GOOGLE_STREET_VIEW_KEY=

# Mapbox token for geocoding fallback (MapLibre GL uses free tiles)
MAPBOX_TOKEN=

# Sentry error tracking (frontend)
NEXT_PUBLIC_SENTRY_DSN=

# Martin vector tile server URL (Supabase-hosted)
MARTIN_URL=

# ═══════════════════════════════════════════════════════════════════════════════
# [Supabase DB/Auth]
# ═══════════════════════════════════════════════════════════════════════════════

# Backend Supabase connection (FastAPI server-side)
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_JWT_SECRET=

# Async PostgreSQL + PostGIS connection
# Format: postgresql+asyncpg://user:pass@host:5432/capegis
DATABASE_URL=
DATABASE_POOL_SIZE=
DATABASE_MAX_OVERFLOW=

# ═══════════════════════════════════════════════════════════════════════════════
# [Backend — FastAPI on Railway]
# ═══════════════════════════════════════════════════════════════════════════════

APP_NAME=
APP_VERSION=
DEBUG=

# Celery + Redis (Railway Redis add-on)
CELERY_BROKER_URL=
CELERY_RESULT_BACKEND=
REDIS_URL=

# CORS (Vercel domain only in production — no wildcard)
CORS_ORIGINS=

# ═══════════════════════════════════════════════════════════════════════════════
# [Premium Enterprise Geospatial Stack]
# Architecture: Pivot to managed services (Cesium ion) for raster/3D assets.
# Reducing custom infrastructure footprint.
# ═══════════════════════════════════════════════════════════════════════════════

# Cesium ion Access Token for automated 3D/raster tiling and hosting
# Generate at: https://ion.cesium.com/tokens
CESIUM_ION_ACCESS_TOKEN=

# GCP configuration (used only for temporary staging of GEE exports)
GCP_PROJECT_ID=
GCS_BUCKET_NAME=

# Service Account key path — GEE Writer (Earth Engine export pipeline)
# Deadline: April 27, 2026 (GEE quota tier cutoff)
GEE_SA_KEY_PATH=

# ═══════════════════════════════════════════════════════════════════════════════
# [ML Services]
# ═══════════════════════════════════════════════════════════════════════════════

ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# Google CrUX API key (for Core Web Vitals performance tracking)
GOOGLE_CRUX_API_KEY=
