# CapeTown GIS Hub — Environment Variables Template
# Copy to .env and fill in values. Never commit .env to git.

# === Frontend (Next.js) ===
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
NEXT_PUBLIC_GOOGLE_STREET_VIEW_KEY=
MAPBOX_TOKEN=
NEXT_PUBLIC_SENTRY_DSN=
MARTIN_URL=

# === Backend (FastAPI on Railway) ===
APP_NAME=
APP_VERSION=
DEBUG=

# Supabase Auth (JWKS validation — not shared secret)
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_JWT_SECRET=

# Database (async PostgreSQL + PostGIS)
DATABASE_URL=
DATABASE_POOL_SIZE=
DATABASE_MAX_OVERFLOW=

# Celery + Redis (Railway Redis add-on)
CELERY_BROKER_URL=
CELERY_RESULT_BACKEND=
REDIS_URL=

# Cloudflare R2 Object Storage (rasters, models, files >50MB)
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_ENDPOINT_URL=
R2_BUCKET_NAME=

# ML Services
ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# CORS (Vercel domain only in production — no wildcard)
CORS_ORIGINS=
