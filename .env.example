# ==============================================================================
# CapeTown GIS Hub (capegis) — Environment Variables (v4 template)
# Documentation-only template: NEVER commit real values to Git.
# ==============================================================================

# =========================
# CORE APP CONFIG
# =========================
# Supabase project configuration (Auth & Database)
NEXT_PUBLIC_SUPABASE_URL=your_supabase_url_here
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key_here
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key_here

# Local Infrastructure & Database
DATABASE_URL=postgresql://user:password@localhost:5432/capegis
POSTGRES_DB=capegis
POSTGRES_USER=postgres
POSTGRES_PASSWORD=your_postgres_password_here

# Vector Tile Services
MARTIN_URL=http://localhost:3000

# =========================
# API KEYS
# =========================
# AI & Search LLM Providers
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_DEEP_RESEARCH_API_KEY=your_gemini_deep_research_key_here
CONTEXT7_API_KEY=your_context7_api_key_here
EXA_API_KEY=your_exa_api_key_here

# Google Cloud & Mapping APIs
GOOGLE_API_KEY=your_google_api_key_here
GOOGLE_STITCH_API_KEY=your_google_stitch_api_key_here
NEXT_PUBLIC_GOOGLE_STREET_VIEW_KEY=your_google_street_view_key_here
MAPBOX_TOKEN=your_mapbox_token_here

# Infrastructure & Other
VERCEL_TOKEN=your_vercel_token_here

# =========================
# MCP SERVERS
# =========================
# Configuration for Model Context Protocol (MCP) server fleet

# MCP Tooling Configuration
MCP_TOOL_TIMEOUT_MS=30000
MCP_LOG_LEVEL=info
MCP_RATE_LIMIT_PER_MINUTE=60
MCP_MAX_CONCURRENT_TOOLS=5

# MCP-Specific Authentication Tokens
COPILOT_MCP_CESIUM_ION_TOKEN=your_mcp_cesium_ion_token_here

# Tool-Specific Logic & Paths
NERFSTUDIO_PATH=/path/to/nerfstudio
MCP_STITCH_NERFSTUDIO_PATH=/path/to/nerfstudio

# =========================
# FIRECRAWL
# =========================
# Web scraping and crawling for automated data ingestion
FIRECRAWL_API_KEY=your_firecrawl_api_key_here
FIRECRAWL_API_URL=https://api.firecrawl.dev

# =========================
# BROWSERBASE
# =========================
# Headless browser automation for complex web tasks
BROWSERBASE_API_KEY=your_browserbase_api_key_here
BROWSERBASE_PROJECT_ID=your_browserbase_project_id_here

# =========================
# STRIPE PAYMENTS
# =========================
# Multi-tenant billing and subscription integration
STRIPE_SECRET_KEY=your_stripe_secret_key_here
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=your_stripe_publishable_key_here
STRIPE_WEBHOOK_SECRET=your_stripe_webhook_secret_here

# =========================
# DOPPLER CONFIG
# =========================
# Doppler CLI configuration for secrets management
DOPPLER_TOKEN=your_doppler_token_here
DOPPLER_PROJECT=capegis
DOPPLER_CONFIG=dev
DOPPLER_ENVIRONMENT=development

# =========================
# CARTO
# =========================
# Geospatial analytics and advanced visualization
CARTO_API_KEY=your_carto_api_key_here
CARTO_USERNAME=your_carto_username_here
CARTO_CLIENT_ID=your_carto_client_id_here
CARTO_CLIENT_SECRET=your_carto_client_secret_here

# =========================
# OPENSKY NETWORK
# =========================
# Aviation data for flight tracking over Western Cape
OPENSKY_USERNAME=your_opensky_username_here
OPENSKY_PASSWORD=your_opensky_password_here

# =========================
# OBSERVABILITY / DATA PROVIDERS
# =========================
# Error tracking and monitoring
NEXT_PUBLIC_SENTRY_DSN=your_sentry_dsn_here

# GIS Data Providers
CESIUM_ION_TOKEN=your_cesium_ion_token_here
ARCGIS_CLIENT_ID=your_arcgis_client_id_here
ARCGIS_CLIENT_SECRET=your_arcgis_client_secret_here

# =========================
# AUTH & SECURITY
# =========================
# Security environment and auth helpers
LOCALSTACK_AUTH_TOKEN=your_localstack_token_here
JWT_SECRET=your_jwt_secret_here
NEXTAUTH_SECRET=your_nextauth_secret_here
