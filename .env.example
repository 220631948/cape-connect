# CapeTown GIS Hub — Environment Variables Template
# Copy to .env and fill in values. Never commit .env to git.

# ═══════════════════════════════════════════════════════════════════════════════
# [Next.js Core]
# ═══════════════════════════════════════════════════════════════════════════════

# Supabase client-side connection (public, safe to expose in browser)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Server-side Supabase key (NEVER expose to browser — server routes only)
SUPABASE_SERVICE_ROLE_KEY=

# Google Street View integration for property detail views
NEXT_PUBLIC_GOOGLE_STREET_VIEW_KEY=

# Mapbox token for geocoding fallback (MapLibre GL uses free tiles)
MAPBOX_TOKEN=

# Sentry error tracking (frontend)
NEXT_PUBLIC_SENTRY_DSN=

# Martin vector tile server URL (Supabase-hosted)
MARTIN_URL=

# ═══════════════════════════════════════════════════════════════════════════════
# [Supabase DB/Auth]
# ═══════════════════════════════════════════════════════════════════════════════

# Backend Supabase connection (FastAPI server-side)
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_JWT_SECRET=

# Async PostgreSQL + PostGIS connection
# Format: postgresql+asyncpg://user:pass@host:5432/capegis
DATABASE_URL=
DATABASE_POOL_SIZE=
DATABASE_MAX_OVERFLOW=

# ═══════════════════════════════════════════════════════════════════════════════
# [Backend — FastAPI on Railway]
# ═══════════════════════════════════════════════════════════════════════════════

APP_NAME=
APP_VERSION=
DEBUG=

# Celery + Redis (Railway Redis add-on)
CELERY_BROKER_URL=
CELERY_RESULT_BACKEND=
REDIS_URL=

# CORS (Vercel domain only in production — no wildcard)
CORS_ORIGINS=

# ═══════════════════════════════════════════════════════════════════════════════
# [NEW: GCP Raster Offload]
# Architecture: Hybrid — vector data stays in Supabase PostGIS,
# raster COGs live in GCS africa-south1 (POPIA compliant).
# See docs/architecture/hybrid-offload-plan.md
# ═══════════════════════════════════════════════════════════════════════════════

# Cloud Run proxy URL for signed URL generation + raster processing
# Set after running: gcloud run services describe capegis-raster-processor --format="value(status.url)"
NEXT_PUBLIC_RASTER_BASE_URL=

# GCS public URL for direct COG range requests (HTTP 206)
# Format: https://storage.googleapis.com/<bucket-name>
NEXT_PUBLIC_GCS_PUBLIC_URL=

# GCS bucket name (africa-south1, Standard → Nearline after 90d)
GCS_BUCKET_NAME=

# GCP project ID
GCP_PROJECT_ID=

# Service Account key path — Reader (proxy, signed URLs)
# In production: use Workload Identity Federation instead of JSON keys
GCP_SA_KEY_PATH=

# Service Account key path — GEE Writer (Earth Engine export pipeline)
# Deadline: April 27, 2026 (GEE quota tier cutoff)
GEE_SA_KEY_PATH=

# ═══════════════════════════════════════════════════════════════════════════════
# [Legacy: Cloudflare R2 — being migrated to GCS]
# These will be removed after migration completes.
# ═══════════════════════════════════════════════════════════════════════════════

R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_ENDPOINT_URL=
R2_BUCKET_NAME=

# ═══════════════════════════════════════════════════════════════════════════════
# [ML Services]
# ═══════════════════════════════════════════════════════════════════════════════

ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# Google CrUX API key (for Core Web Vitals performance tracking)
GOOGLE_CRUX_API_KEY=
