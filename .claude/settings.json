{
  "enabledPlugins": {
    "notebooklm-connector@claude-code-zero": true,
    "claude-mem@thedotmack": true
  },
  "mcpServers": {
    "filesystem": {
      "command": "npx",
      "args": [
        "-y",
        "@modelcontextprotocol/server-filesystem",
        "/home/mr/Desktop/Geographical Informations Systems (GIS)"
      ],
      "type": "stdio"
    },
    "postgres": {
      "command": "npx",
      "args": [
        "-y",
        "@modelcontextprotocol/server-postgres",
        "postgresql://postgres:postgres@localhost:5432/capegis"
      ],
      "type": "stdio"
    },
    "doc-state": {
      "command": "node",
      "args": [
        "mcp/doc-state/server.js"
      ],
      "type": "stdio"
    },
    "formats": {
      "command": "node",
      "args": [
        "mcp/formats/server.js"
      ],
      "type": "stdio"
    },
    "cesium": {
      "command": "node",
      "args": [
        "mcp/cesium/server.js"
      ],
      "type": "stdio"
    },
    "openaware": {
      "command": "node",
      "args": [
        "mcp/openaware/server.js"
      ],
      "type": "stdio"
    },
    "stitch": {
      "command": "node",
      "args": [
        "mcp/stitch/server.js"
      ],
      "env": {
        "NERFSTUDIO_PATH": "/usr/local/bin/ns-train"
      },
      "type": "stdio"
    },
    "computerUse": {
      "command": "node",
      "args": [
        "mcp/computerUse/server.js"
      ],
      "type": "stdio"
    },
    "opensky": {
      "command": "node",
      "args": [
        "scripts/opensky-mcp-wrapper.js"
      ],
      "type": "stdio"
    },
    "gis-mcp": {
      "command": "uvx",
      "args": [
        "gis-mcp"
      ],
      "type": "stdio"
    },
    "context7": {
      "command": "npx",
      "args": [
        "-y",
        "@upstash/context7-mcp"
      ],
      "env": {
        "CONTEXT7_API_KEY": "${CONTEXT7_API_KEY}"
      },
      "type": "stdio"
    },
    "exa": {
      "command": "npx",
      "args": [
        "-y",
        "exa-mcp-server"
      ],
      "type": "stdio"
    },
    "playwright": {
      "command": "npx",
      "args": [
        "-y",
        "@playwright/mcp@latest"
      ],
      "type": "stdio"
    },
    "chrome-devtools": {
      "command": "npx",
      "args": [
        "-y",
        "chrome-devtools-mcp"
      ],
      "type": "stdio"
    },
    "docker": {
      "command": "npx",
      "args": [
        "-y",
        "docker-mcp"
      ],
      "type": "stdio"
    },
    "localstack": {
      "command": "npx",
      "args": [
        "-y",
        "@localstack/localstack-mcp-server"
      ],
      "type": "stdio"
    },
    "vercel": {
      "command": "npx",
      "args": [
        "-y",
        "--package",
        "@vercel/sdk",
        "--",
        "mcp",
        "start"
      ],
      "env": {
        "VERCEL_TOKEN": "${VERCEL_TOKEN}"
      },
      "type": "stdio"
    },
    "sequentialthinking": {
      "command": "docker",
      "args": [
        "run",
        "-i",
        "--rm",
        "danielapatin/sequentialthinking:latest",
        "-transport",
        "stdio"
      ],
      "type": "stdio"
    },
    "cesium-ion": {
      "type": "sse",
      "url": "https://mcp.cesium.com/sse",
      "headers": {
        "Authorization": "Bearer ${COPILOT_MCP_CESIUM_ION_TOKEN}"
      }
    },
    "nerfstudio": {
      "command": "python",
      "args": [
        "-m",
        "nerfstudio.mcp_server"
      ],
      "type": "stdio"
    },
    "nano-banana": {
      "type": "http",
      "url": "https://nano-banana.googleapis.com/mcp",
      "headers": {
        "Authorization": "Bearer ${GOOGLE_API_KEY}"
      },
      "timeout_ms": 20000,
      "retry_attempts": 3
    },
    "notebooklm": {
      "type": "stdio",
      "command": "npx",
      "args": [
        "notebooklm-mcp@latest"
      ],
      "env": {}
    },
    "azure-mcp": {
      "type": "stdio",
      "command": "uvx",
      "args": [
        "--from",
        "msmcp-azure",
        "azmcp",
        "server",
        "start"
      ],
      "env": {}
    },
    "huggingface-skills": {
      "url": "https://huggingface.co/mcp?login"
    }
  }
}